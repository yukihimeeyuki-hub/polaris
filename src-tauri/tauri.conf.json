{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "polaris",
  "version": "0.1.0",
  "identifier": "yukihimeeyuki_hub.client.polaris",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "polaris",
        "width": 800,
        "height": 600
      },{
        "label": "StatusWindow",
        "title": "",
        "width": 100,
        "height": 100,
        "closable": false,
        "url": "/PromptBox",
        "backgroundColor": "#00000000",
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true

      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": {
        "title": "更新提示",
        "message": "检测到新版本，是否下载并安装？",
        "buttons": ["取消", "下载并安装"],
        "cancelButton": 0,
        "updateButton": 1
      },
      "endpoint": "https://api.github.com/repos/yukihimeeyuki/polaris/releases/latest.json",
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ2REIxRDZGRTNFQkNGMTEKUldRUnordmpieDNiMXZmUTNHdTlFQnB5QitWYS9JSEc1akxma0lCSTNBanpIVElJaC9mdkdxTTkK"
    }
  }
}
